{
  "info": {
    "name": "R-Tienda API Full",
    "description": "Colección completa de todas las rutas del backend R-Tienda, incluyendo Autenticación, Inventario, Categorías, Ventas, Cajas, Agentes, Personas y Usuarios.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer <token>" }
            ],
            "url": {
              "raw": "http://localhost:3000/auth/refresh_token",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "refresh_token"]
            }
          }
        }
      ]
    },
